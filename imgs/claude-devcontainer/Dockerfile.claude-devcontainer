FROM claude-base:latest

USER root

# Install editors: classic vim (no plugins) + apt build deps already in base
RUN apt-get update && apt-get install -y vim && rm -rf /var/lib/apt/lists/*

USER claude

# Install latest Neovim from GitHub releases
RUN curl -fsSL https://github.com/neovim/neovim/releases/download/v0.11.5/nvim-linux-x86_64.tar.gz -o ~/.tmp/nvim.tar.gz && \
    tar -xzf ~/.tmp/nvim.tar.gz -C ~/.opt && \
    ln -s ~/.opt/nvim-linux-x86_64/bin/nvim ~/.local/bin/nvim && \
    rm -f ~/.tmp/nvim.tar.gz

USER root

# Copy devcontainer entrypoint (context: repo root)
COPY imgs/claude-devcontainer/entrypoint-claude-devcontainer.sh /workspace/container_run.sh
RUN chmod +x /workspace/container_run.sh && chown claude:claude /workspace/container_run.sh

USER claude

ENTRYPOINT ["/workspace/container_run.sh"]
