FROM claude-devcontainer:latest as base

USER root

RUN mkdir -p /workspace/output /config && \
    chown -R claude:claude /workspace /config

# Install jq
RUN apt-get update && apt-get install -y jq

# Copy agent orchestrator script
COPY entrypoint-claude-agent.sh /workspace/agent
RUN chmod +x /workspace/agent && chown claude:claude /workspace/agent

USER claude

# Set entrypoint to agent orchestrator
ENTRYPOINT ["/workspace/agent"]
